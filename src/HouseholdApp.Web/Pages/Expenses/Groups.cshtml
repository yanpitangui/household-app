@page "/h/{householdId:guid}/Expenses/Groups"
@model HouseholdApp.Web.Pages.Expenses.ExpenseGroupsModel
@{
    ViewData["Title"] = "Expense Groups";
}

<div class="page-heading">
    <span>@L["Expenses.GroupsHeading"]</span>
    <a asp-page="Index" asp-route-householdId="@Model.HouseholdId" style="font-family:var(--font-body); font-size:13px; color:var(--text-muted); text-decoration:none; font-weight:500">← @L["Action.Back"]</a>
</div>

<div class="app-card mb-4">
    <div class="section-title" style="margin-top:0">@L["Expenses.NewGroup"]</div>
    <form method="post" asp-page-handler="Create">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">@L["Expenses.GroupName"]</label>
                <input asp-for="NewName" class="form-control" placeholder="e.g. Groceries" />
                <span asp-validation-for="NewName" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-md-5">
                <label class="form-label">@L["Expenses.GroupDescription"]</label>
                <input asp-for="NewDescription" class="form-control" placeholder="Details..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">+ @L["Action.Create"]</button>
            </div>
        </div>
    </form>
</div>

@if (!Model.Groups.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var g in Model.Groups)
    {
        <div class="list-row">
            <div class="list-row-icon" style="background:rgba(59,130,246,0.12)">💳</div>
            <div class="list-row-body">
                <div class="list-row-name">@g.Name</div>
                @if (g.Description is not null)
                {
                    <div class="list-row-meta">@g.Description</div>
                }
            </div>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                <input type="hidden" name="groupId" value="@g.Id" />
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        data-confirm="Delete group '@g.Name'? Cannot delete groups with active expenses.">@L["Action.Delete"]</button>
            </form>
        </div>
    }
}
