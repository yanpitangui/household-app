@page "/h/{householdId:guid}/Expenses/Recurring"
@model HouseholdApp.Web.Pages.Expenses.RecurringExpensesModel
@{
    ViewData["Title"] = "Recurring Expenses";
}

<div class="page-heading">
    <span>@L["Expenses.RecurringHeading"]</span>
    <a asp-page="Index" asp-route-householdId="@Model.HouseholdId" style="font-family:var(--font-body); font-size:13px; color:var(--text-muted); text-decoration:none; font-weight:500">← @L["Action.Back"]</a>
</div>

<div class="app-card mb-4">
    <div class="section-title" style="margin-top:0">@L["Expenses.NewRecurring"]</div>
    <form method="post" asp-page-handler="Create">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@L["Expenses.Description"]</label>
                <input asp-for="NewDescription" class="form-control" placeholder="e.g. Netflix" />
                <span asp-validation-for="NewDescription" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">@L["Expenses.Group"]</label>
                <select asp-for="NewGroupId" class="form-select">
                    @foreach (var g in Model.Groups)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">@L["Expenses.Amount"]</label>
                <input asp-for="NewAmountReais" type="number" step="0.01" min="0.01" class="form-control" />
                <span asp-validation-for="NewAmountReais" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">@L["Expenses.CronExpression"]</label>
                <input asp-for="NewCronExpression" class="form-control" placeholder="0 9 1 * *" />
                <span asp-validation-for="NewCronExpression" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">@L["Expenses.Payer"]</label>
                <select asp-for="NewPayerId" class="form-select">
                    @foreach (var m in Model.Members)
                    {
                        <option value="@m.UserId">@m.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">@L["Expenses.SplitAmong"]</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var m in Model.Members)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="NewSplitMemberIds" value="@m.UserId"
                                   id="split_@m.UserId" />
                            <label class="form-check-label" style="color:var(--text-secondary); font-size:13px" for="split_@m.UserId">@m.DisplayName</label>
                        </div>
                    }
                </div>
                <span asp-validation-for="NewSplitMemberIds" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">+ @L["Action.Create"]</button>
            </div>
        </div>
    </form>
</div>

@if (!Model.RecurringExpenses.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var e in Model.RecurringExpenses)
    {
        <div class="list-row" style="align-items:flex-start">
            <div class="list-row-icon" style="background:rgba(59,130,246,0.12)">💳</div>
            <div class="list-row-body">
                <div class="list-row-name" style="@(!e.IsActive ? "color:var(--text-muted)" : "")">@e.Description</div>
                <div class="list-row-meta">
                    @(Model.GroupNames.GetValueOrDefault(e.ExpenseGroupId, "?"))
                    · <code style="font-size:11px; color:var(--text-secondary)">@e.CronExpression</code>
                </div>
            </div>
            @if (e.IsActive)
            {
                <span class="list-row-badge" style="background:rgba(59,130,246,0.12); color:var(--accent-expenses)">@L["Expenses.Active"]</span>
                <form method="post" asp-page-handler="Deactivate" style="display:inline">
                    <input type="hidden" name="recurringExpenseId" value="@e.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            data-confirm="Deactivate this recurring expense?">@L["Expenses.Deactivate"]</button>
                </form>
            }
            else
            {
                <span class="list-row-badge" style="background:rgba(74,56,40,0.3); color:var(--text-muted)">@L["Expenses.Inactive"]</span>
            }
        </div>
    }
}
