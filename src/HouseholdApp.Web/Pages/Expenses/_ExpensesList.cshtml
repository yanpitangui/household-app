@model HouseholdApp.Web.Pages.Expenses.ExpensesListViewModel
@using System.Globalization
@{
    var currencySymbol = CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol;
    var grouped = Model.Expenses
        .GroupBy(e => new { e.Date.Year, e.Date.Month })
        .OrderByDescending(g => g.Key.Year)
        .ThenByDescending(g => g.Key.Month);
}

<div id="expenses-list">
@if (!Model.Expenses.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var grp in grouped)
    {
        var monthLabel = new DateTime(grp.Key.Year, grp.Key.Month, 1).ToString("MMMM yyyy");
        <div class="expenses-month-header">@monthLabel</div>

        @foreach (var e in grp.OrderByDescending(x => x.Date))
        {
            var myFunding = e.FundingSources.FirstOrDefault(f => f.UserId == Model.CurrentUserId)?.Cents ?? 0;
            var myAllocation = e.Allocations.FirstOrDefault(a => a.UserId == Model.CurrentUserId)?.Cents ?? 0;
            var myNet = myFunding - myAllocation;
            var isParticipant = myFunding > 0 || myAllocation > 0;
            var hasMultiplePayers = e.FundingSources.Count > 1;
            var paidLabel = hasMultiplePayers
                ? L["Expenses.Breakdown.PaidPlural"].Value
                : L["Expenses.Breakdown.PaidSingular"].Value;
            var rowId = $"exp-{e.Id:N}";

            <div class="expense-row-wrap" id="@rowId">
                <div class="expense-row-header">
                    <div class="expenses-date-col">
                        <span class="expenses-date-month">@e.Date.ToString("MMM")</span>
                        <span class="expenses-date-day">@e.Date.Day</span>
                    </div>
                    <div class="list-row-icon" style="background:rgba(59,130,246,0.12);width:30px;height:30px;border-radius:8px;font-size:14px;flex-shrink:0">
                        💳
                    </div>
                    <div class="list-row-body">
                        <div class="list-row-name">@e.Description</div>
                        <div class="list-row-meta">
                            @foreach (var f in e.FundingSources)
                            {
                                if (f.UserId == Model.CurrentUserId)
                                {
                                    <span>@L["Expenses.YouPaid"] @currencySymbol @((f.Cents / 100m).ToString("F2"))</span>
                                }
                                else
                                {
                                    <span class="payer-chip">
                                        <span class="payer-init">
                                            @if (!string.IsNullOrEmpty(f.PictureUrl))
                                            {
                                                <img src="@f.PictureUrl" alt="@f.DisplayName" />
                                            }
                                            else
                                            {
                                                @(f.DisplayName.Length > 0 ? f.DisplayName[0] : '?')
                                            }
                                        </span>
                                        @(f.DisplayName.Split(' ')[0]) @paidLabel
                                    </span>
                                }
                            }
                        </div>
                    </div>
                    <div class="expense-row-right">
                        <span class="list-row-badge" style="background:rgba(59,130,246,0.12);color:var(--accent-expenses);font-size:12px;font-weight:700">
                            @currencySymbol @((e.TotalCents / 100m).ToString("F2"))
                        </span>
                        @if (isParticipant && myNet != 0)
                        {
                            <span class="expenses-user-share @(myNet > 0 ? "lent" : "borrowed")">
                                @currencySymbol @((Math.Abs(myNet) / 100m).ToString("F2"))
                            </span>
                            <span class="expenses-share-label">
                                @(myNet > 0 ? L["Expenses.YouLent"].Value : L["Expenses.YouBorrowed"].Value)
                            </span>
                        }
                        @if (e.FundingSources.Any())
                        {
                            <span class="expand-arrow">▾</span>
                        }
                    </div>
                </div>

                <div class="expense-breakdown">
                    <div class="expense-breakdown-cols">
                        <div>
                            <div class="expense-breakdown-label">@L["Expenses.Breakdown.WhoPaid"]</div>
                            @foreach (var f in e.FundingSources)
                            {
                                <div class="expense-breakdown-entry">
                                    <span class="expense-breakdown-person">
                                        <span class="expense-breakdown-avatar">
                                            @if (!string.IsNullOrEmpty(f.PictureUrl))
                                            {
                                                <img src="@f.PictureUrl" alt="@f.DisplayName" />
                                            }
                                            else
                                            {
                                                @(f.DisplayName.Length > 0 ? f.DisplayName[0] : '?')
                                            }
                                        </span>
                                        @f.DisplayName
                                    </span>
                                    <span class="expense-breakdown-paid">@currencySymbol @((f.Cents / 100m).ToString("F2"))</span>
                                </div>
                            }
                        </div>
                        <div>
                            <div class="expense-breakdown-label">@L["Expenses.Breakdown.HowSplit"]</div>
                            @foreach (var a in e.Allocations)
                            {
                                <div class="expense-breakdown-entry">
                                    <span class="expense-breakdown-person">
                                        <span class="expense-breakdown-avatar">
                                            @if (!string.IsNullOrEmpty(a.PictureUrl))
                                            {
                                                <img src="@a.PictureUrl" alt="@a.DisplayName" />
                                            }
                                            else
                                            {
                                                @(a.DisplayName.Length > 0 ? a.DisplayName[0] : '?')
                                            }
                                        </span>
                                        @a.DisplayName
                                    </span>
                                    <span class="expense-breakdown-owe">@currencySymbol @((a.Cents / 100m).ToString("F2"))</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="expense-breakdown-footer">
                        <a href="/h/@Model.HouseholdId/expenses/record?expenseId=@e.Id"
                           class="btn btn-sm btn-outline-secondary">
                            @L["Expenses.EditEntry"]
                        </a>
                        <form method="post" action="/h/@Model.HouseholdId/expenses?handler=Void" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="expenseId" value="@e.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    data-confirm="@L["Expenses.Breakdown.VoidConfirm"]">
                                @L["Expenses.VoidEntry"]
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
}
</div>
