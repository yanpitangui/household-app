@page "/h/{householdId:guid}/Expenses/Record"
@model HouseholdApp.Web.Pages.Expenses.RecordExpenseModel
@{
    ViewData["Title"] = "Record Expense";
}

<div class="page-heading">
    <span>@L["Expenses.RecordExpenseHeading"]</span>
    <a asp-page="Index" asp-route-householdId="@Model.HouseholdId" style="font-family:var(--font-body); font-size:13px; color:var(--text-muted); text-decoration:none; font-weight:500">← @L["Action.Cancel"]</a>
</div>

<div class="app-card">
    <form method="post">

        <div class="mb-3">
            <label asp-for="Description" class="form-label">@L["Expenses.Description"]</label>
            <input asp-for="Description" class="form-control" placeholder="e.g. Groceries" />
        </div>

        <div class="row mb-3">
            <div class="col">
                <label asp-for="Date" class="form-label">@L["Expenses.Date"]</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>
            <div class="col">
                <label asp-for="AmountReais" class="form-label">@L["Expenses.Amount"]</label>
                <input asp-for="AmountReais" type="number" step="0.01" min="0.01" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="GroupId" class="form-label">@L["Expenses.Group"]</label>
            <select asp-for="GroupId" class="form-select">
                <option value="">-- Select group --</option>
                @foreach (var g in Model.Groups)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="PayerId" class="form-label">@L["Expenses.Payer"]</label>
            <select asp-for="PayerId" class="form-select">
                @foreach (var m in Model.Members)
                {
                    <option value="@m.UserId" selected="@(m.UserId == Model.CurrentUserId)">@m.DisplayName</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label">@L["Expenses.Participants"]</label>
            @foreach (var m in Model.Members)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           name="SplitMemberIds" value="@m.UserId" checked="checked"
                           id="split_@m.UserId" />
                    <label class="form-check-label" style="color:var(--text-secondary); font-size:13px" for="split_@m.UserId">@m.DisplayName</label>
                </div>
            }
            <small style="color:var(--text-muted); font-size:11px">@L["Expenses.EqualSplitHint"]</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">@L["Expenses.Record"]</button>
            <a asp-page="Index" asp-route-householdId="@Model.HouseholdId" class="btn btn-outline-secondary">@L["Action.Cancel"]</a>
        </div>
    </form>
</div>
