@page "/h/{householdId:guid}/Expenses"
@model HouseholdApp.Web.Pages.Expenses.ExpensesIndexModel
@{
    ViewData["Title"] = "Expenses";
}

<div class="page-heading">
    <span>@L["Nav.Expenses"]</span>
    <div class="d-flex gap-2">
        <a asp-page="Record" asp-route-householdId="@Model.HouseholdId" class="btn btn-primary btn-sm">@L["Expenses.RecordExpense"]</a>
        <a asp-page="Settle" asp-route-householdId="@Model.HouseholdId" class="btn btn-outline-secondary btn-sm">@L["Expenses.SettleUp"]</a>
        <a asp-page="Groups" asp-route-householdId="@Model.HouseholdId" class="btn btn-outline-secondary btn-sm">@L["Expenses.Groups"]</a>
        <a asp-page="Recurring" asp-route-householdId="@Model.HouseholdId" class="btn btn-outline-secondary btn-sm">@L["Expenses.Recurring"]</a>
    </div>
</div>

@if (Model.Balances.Any())
{
    <div class="household-hero mb-4">
        <div class="household-hero-label">@L["Expenses.Balances"]</div>
        @foreach (var b in Model.Balances)
        {
            var amtColor = b.Cents > 0 ? "var(--accent-tasks)" : b.Cents < 0 ? "#f87171" : "var(--text-muted)";
            var label = b.Cents > 0 ? L["Expenses.IsOwed"].Value : b.Cents < 0 ? L["Expenses.Owes"].Value : L["Expenses.Settled"].Value;
            <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid var(--border-color)">
                <span style="color:var(--text-secondary); font-size:14px">@b.DisplayName</span>
                <span style="color:@amtColor; font-weight:600; font-size:14px">
                    @(b.Cents >= 0 ? "+" : "")R$ @((Math.Abs(b.Cents) / 100m).ToString("F2"))
                    <span style="color:var(--text-muted); font-weight:400; font-size:12px">@label</span>
                </span>
            </div>
        }
    </div>
}

@if (!Model.Expenses.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var e in Model.Expenses)
    {
        var hasMultiplePayers = e.FundingSources.Count > 1;
        var paidLabel = hasMultiplePayers
            ? L["Expenses.Breakdown.PaidPlural"].Value
            : L["Expenses.Breakdown.PaidSingular"].Value;
        var rowId = $"exp-{e.Id:N}";

        <div class="expense-row-wrap" id="@rowId"
             style="@(e.IsVoided ? "opacity:0.5" : "")">
            <div class="expense-row-header"
                 onclick="document.getElementById('@rowId').classList.toggle('expanded')">
                <div class="list-row-icon" style="background:rgba(59,130,246,0.12)">💳</div>
                <div class="list-row-body">
                    <div class="list-row-name"
                         style="@(e.IsVoided ? "text-decoration:line-through; color:var(--text-muted)" : "")">
                        @e.Description
                    </div>
                    <div class="list-row-meta">
                        @e.Date.ToString("d")
                        @if (e.FundingSources.Any())
                        {
                            <span style="color:var(--text-muted);margin:0 2px">·</span>
                            @foreach (var f in e.FundingSources)
                            {
                                <span class="payer-chip">
                                    <span class="payer-init">@(f.DisplayName.Length > 0 ? f.DisplayName[0] : '?')</span>
                                    @(hasMultiplePayers ? f.DisplayName.Split(' ')[0] : f.DisplayName)
                                </span>
                            }
                            <span class="payer-paid-label">@paidLabel</span>
                        }
                    </div>
                </div>
                <div class="expense-row-right">
                    <span class="list-row-badge" style="background:rgba(59,130,246,0.12); color:var(--accent-expenses)">
                        R$ @((e.TotalCents / 100m).ToString("F2"))
                    </span>
                    @if (!e.IsVoided && e.FundingSources.Any())
                    {
                        <span class="expand-arrow">▾</span>
                    }
                </div>
            </div>

            @if (!e.IsVoided)
            {
                <div class="expense-breakdown">
                    <div class="expense-breakdown-cols">
                        <div>
                            <div class="expense-breakdown-label">@L["Expenses.Breakdown.WhoPaid"]</div>
                            @foreach (var f in e.FundingSources)
                            {
                                <div class="expense-breakdown-entry">
                                    <span class="expense-breakdown-person">
                                        <span class="expense-breakdown-avatar">@(f.DisplayName.Length > 0 ? f.DisplayName[0] : '?')</span>
                                        @f.DisplayName
                                    </span>
                                    <span class="expense-breakdown-paid">R$ @((f.Cents / 100m).ToString("F2"))</span>
                                </div>
                            }
                        </div>
                        <div>
                            <div class="expense-breakdown-label">@L["Expenses.Breakdown.HowSplit"]</div>
                            @foreach (var a in e.Allocations)
                            {
                                <div class="expense-breakdown-entry">
                                    <span class="expense-breakdown-person">
                                        <span class="expense-breakdown-avatar">@(a.DisplayName.Length > 0 ? a.DisplayName[0] : '?')</span>
                                        @a.DisplayName
                                    </span>
                                    <span class="expense-breakdown-owe">R$ @((a.Cents / 100m).ToString("F2"))</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="expense-breakdown-footer">
                        <form method="post" asp-page-handler="Void" style="display:inline">
                            <input type="hidden" name="expenseId" value="@e.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    data-confirm="@L["Expenses.Breakdown.VoidConfirm"]">@L["Expenses.VoidEntry"]</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
}
