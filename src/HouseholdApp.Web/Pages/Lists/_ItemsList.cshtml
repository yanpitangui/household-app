@model HouseholdApp.Application.Modules.Lists.Application.Ports.ListDetail

@{
    var activeGroups = Model.Items
        .Where(i => !i.IsCompleted)
        .GroupBy(i => new { i.CategoryId, i.CategoryName, i.CategoryEmoji })
        .OrderBy(g => g.Key.CategoryName is null ? 1 : 0)
        .ThenBy(g => g.Key.CategoryName)
        .ToList();

    var doneItems = Model.Items
        .Where(i => i.IsCompleted)
        .OrderBy(i => i.SortOrder)
        .ToList();
}

<div id="items-list" data-list-id="@Model.Id">
    <div class="list-options-menu dropdown">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false" title="@L["Lists.MoreOptions"]">⋯</button>
        <ul class="dropdown-menu dropdown-menu-end">
            @if (activeGroups.Any())
            {
                <li>
                    <button type="button" class="dropdown-item"
                            hx-post="?handler=MarkAllDone"
                            hx-vals='{"ListId": "@Model.Id"}'
                            hx-swap="none">@L["Lists.MarkAllDone"]</button>
                </li>
            }
            else
            {
                <li><button type="button" class="dropdown-item" disabled>@L["Lists.MarkAllDone"]</button></li>
            }
            @if (doneItems.Any())
            {
                <li>
                    <button type="button" class="dropdown-item"
                            hx-post="?handler=UnmarkAll"
                            hx-vals='{"ListId": "@Model.Id"}'
                            hx-swap="none">@L["Lists.UnmarkAll"]</button>
                </li>
            }
            else
            {
                <li><button type="button" class="dropdown-item" disabled>@L["Lists.UnmarkAll"]</button></li>
            }
            <li>
                <button type="button" id="toggle-done-visibility-btn" class="dropdown-item"
                        data-hide-label="@L["Lists.HideDoneItems"]"
                        data-show-label="@L["Lists.ShowDoneItems"]"
                        onclick="toggleDoneVisibility()">@L["Lists.HideDoneItems"]</button>
            </li>
            @if (doneItems.Any())
            {
                <li>
                    <button type="button" class="dropdown-item"
                            hx-post="?handler=RemoveCompletedItems"
                            hx-vals='{"ListId": "@Model.Id"}'
                            hx-swap="none"
                            hx-confirm="@L["Confirm.DeleteDoneItems"]"
                            hx-on::after-request="optimisticRemoveCompletedItems(this, event.detail.successful)">@L["Lists.DeleteDoneItems"]</button>
                </li>
            }
            else
            {
                <li><button type="button" class="dropdown-item" disabled>@L["Lists.DeleteDoneItems"]</button></li>
            }
            <li><hr class="dropdown-divider" /></li>
            <li>
                <button type="button" class="dropdown-item" onclick="document.getElementById('category-manage-dialog')?.showModal(); resetCategoryForm();">@L["Lists.ManageCategories"]</button>
            </li>
        </ul>
    </div>

    @if (!Model.Items.Any())
    {
        <p class="section-title">@L["Lists.NoItems"]</p>
    }
    else
    {
        @foreach (var group in activeGroups)
        {
            var title = group.Key.CategoryName ?? L["Lists.NoCategory"].Value;
            var emoji = group.Key.CategoryName is null ? "" : group.Key.CategoryEmoji + " ";
            <p class="category-group-title">@emoji@title (@group.Count())</p>
            <div class="app-card">
                @foreach (var item in group.OrderBy(i => i.SortOrder))
                {
                    <div class="check-item">
                        <button class="check-box"
                                hx-post="?handler=CompleteItem"
                                hx-vals='{"ListId": "@Model.Id", "ItemId": "@item.Id"}'
                                hx-swap="none"
                                hx-sync="this:abort"
                                hx-on::before-request="optimisticToggleStart(this)"
                                hx-on::response-error="optimisticToggleRevert(this)"
                                hx-on::send-error="optimisticToggleRevert(this)"
                                >✓</button>
                        <span class="check-item-text"
                              style="flex:1; cursor:pointer"
                              onclick="showItemDetail(this)"
                              data-item-id="@item.Id"
                              data-list-id="@Model.Id"
                              data-name="@item.Name"
                              data-category-id="@(item.CategoryId?.ToString() ?? "")"
                              data-category="@item.CategoryName"
                              data-category-emoji="@item.CategoryEmoji"
                              data-added-by="@item.AddedByName"
                              data-list-name="@Model.Name">
                            @if (item.Quantity is not null || item.Unit is not null)
                            {
                                <span style="color:var(--text-muted);font-size:11px;margin-right:4px">@item.Quantity@(item.Quantity is not null && item.Unit is not null ? " " : "")@item.Unit</span>
                            }
                            @item.Name
                        </span>
                        <button class="btn btn-sm btn-outline-danger"
                                hx-post="?handler=RemoveItem"
                                hx-vals='{"ListId": "@Model.Id", "ItemId": "@item.Id"}'
                                hx-swap="none"
                                hx-confirm="@L["Confirm.RemoveItem"]">✕</button>
                    </div>
                }
            </div>
        }

        @if (doneItems.Any())
        {
            <p class="section-title" id="done-section-title">@L["Tasks.Done"]</p>
            <div class="app-card" id="done-items-card">
                @foreach (var item in doneItems)
                {
                    <div class="check-item done">
                        <button class="check-box checked"
                                hx-post="?handler=UncompleteItem"
                                hx-vals='{"ListId": "@Model.Id", "ItemId": "@item.Id"}'
                                hx-swap="none"
                                hx-sync="this:abort"
                                hx-on::before-request="optimisticToggleStart(this)"
                                hx-on::response-error="optimisticToggleRevert(this)"
                                hx-on::send-error="optimisticToggleRevert(this)"
                                >✓</button>
                        <div style="flex:1; min-width:0; cursor:pointer"
                             onclick="showItemDetail(this)"
                             data-item-id="@item.Id"
                             data-list-id="@Model.Id"
                             data-name="@item.Name"
                             data-category-id="@(item.CategoryId?.ToString() ?? "")"
                             data-category="@item.CategoryName"
                             data-category-emoji="@item.CategoryEmoji"
                             data-added-by="@item.AddedByName"
                             data-list-name="@Model.Name">
                            <span class="check-item-text">
                                @if (item.Quantity is not null || item.Unit is not null)
                                {
                                    <span style="color:var(--text-muted);font-size:11px;margin-right:4px">@item.Quantity@(item.Quantity is not null && item.Unit is not null ? " " : "")@item.Unit</span>
                                }
                                @item.Name
                            </span>
                            @if (item.CategoryName is not null)
                            {
                                <div style="margin-top:3px">
                                    <span class="list-row-badge" style="background:rgba(245,158,11,0.12); color:var(--accent-lists)">
                                        @item.CategoryEmoji @item.CategoryName
                                    </span>
                                </div>
                            }
                        </div>
                        <button class="btn btn-sm btn-outline-danger"
                                hx-post="?handler=RemoveItem"
                                hx-vals='{"ListId": "@Model.Id", "ItemId": "@item.Id"}'
                                hx-swap="none"
                                hx-confirm="@L["Confirm.RemoveItem"]">✕</button>
                    </div>
                }
            </div>
        }
    }
</div>
