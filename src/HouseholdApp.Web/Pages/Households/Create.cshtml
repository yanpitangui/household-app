@page
@model HouseholdApp.Web.Pages.Households.CreateHouseholdModel
@{
    ViewData["Title"] = L["Households.CreateHeading"];
}

<div class="page-heading">
    <span>@L["Households.CreateHeading"]</span>
    <a asp-page="Index" style="font-family:var(--font-body); font-size:13px; color:var(--text-muted); text-decoration:none; font-weight:500">← @L["Action.Cancel"]</a>
</div>

<div class="app-card">
    <form method="post">
        <div class="mb-4">
            <label asp-for="Name" class="form-label">@L["Households.NameLabel"]</label>
            <input asp-for="Name" class="form-control" placeholder="@L["Households.NamePlaceholder"]" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">@L["Action.Create"]</button>
            <a asp-page="Index" class="btn btn-outline-secondary">@L["Action.Cancel"]</a>
        </div>
    </form>
</div>
