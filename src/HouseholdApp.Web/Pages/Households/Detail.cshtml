@page "/h/{id:guid}"
@model HouseholdApp.Web.Pages.Households.HouseholdDetailModel
@{
    ViewData["Title"] = Model.Household?.Name ?? L["Common.Household"].Value;
    ViewData["HouseholdName"] = Model.Household?.Name;
}

@if (Model.Household is null)
{
    <p style="color:var(--text-secondary)">@L["Dashboard.HouseholdNotFound"]</p>
    return;
}

<div class="household-hero">
    <div class="household-hero-label">@L["Dashboard.YourHousehold"]</div>
    <div class="household-hero-name">@Model.Household.Name</div>
</div>

<div id="push-opt-in-banner" class="push-opt-in-banner" style="display:none" data-vapid-public-key="@Model.VapidPublicKey">
    <span id="push-prompt-text">@L["Push.EnablePrompt"]</span>
    <span id="push-enabled-text" style="display:none">@L["Push.Enabled"]</span>
    <button id="push-enable-btn" type="button" class="btn btn-sm btn-primary">@L["Push.Enable"]</button>
    <button id="push-disable-btn" type="button" class="btn btn-sm btn-outline-secondary" style="display:none">@L["Push.Disable"]</button>
    <button id="push-dismiss-btn" type="button" class="btn btn-sm btn-outline-secondary">@L["Action.Dismiss"]</button>
</div>

<div class="feature-grid">
    <a href="/h/@Model.Household.Id/lists" class="feature-card">
        <div class="feature-card-pip" style="background:var(--accent-lists)"></div>
        <div class="feature-card-title">@L["Feature.Lists.Title"]</div>
        <div class="feature-card-subtitle">@L["Feature.Lists.Subtitle"]</div>
        <div class="feature-card-icon">🛒</div>
    </a>
    <a href="/h/@Model.Household.Id/tasks" class="feature-card">
        <div class="feature-card-pip" style="background:var(--accent-tasks)"></div>
        <div class="feature-card-title">@L["Feature.Tasks.Title"]</div>
        <div class="feature-card-subtitle">@L["Feature.Tasks.Subtitle"]</div>
        <div class="feature-card-icon">✅</div>
    </a>
    <a href="/h/@Model.Household.Id/recipes" class="feature-card">
        <div class="feature-card-pip" style="background:var(--accent-recipes)"></div>
        <div class="feature-card-title">@L["Feature.Recipes.Title"]</div>
        <div class="feature-card-subtitle">@L["Feature.Recipes.Subtitle"]</div>
        <div class="feature-card-icon">🍳</div>
    </a>
    <a href="/h/@Model.Household.Id/expenses" class="feature-card">
        <div class="feature-card-pip" style="background:var(--accent-expenses)"></div>
        <div class="feature-card-title">@L["Feature.Expenses.Title"]</div>
        <div class="feature-card-subtitle">@L["Feature.Expenses.Subtitle"]</div>
        <div class="feature-card-icon">💳</div>
    </a>
</div>

<p class="section-title">@L["Dashboard.Members"]</p>
<div class="app-card">
    @foreach (var m in Model.Household.Members)
    {
        <div class="member-item">
            <div style="display:flex;align-items:center">
                <div class="member-avatar">
                    @if (!string.IsNullOrEmpty(m.PictureUrl))
                    {
                        <img src="@m.PictureUrl" alt="@m.DisplayName" />
                    }
                    else
                    {
                        @(m.DisplayName.Length > 0 ? m.DisplayName[0].ToString().ToUpper() : "?")
                    }
                </div>
                <div>
                    <div style="font-size:14px;font-weight:500;color:var(--text-secondary)">@m.DisplayName</div>
                    <div style="font-size:11px;color:var(--text-muted)">@m.Role</div>
                </div>
            </div>
            @if (m.UserId != Model.CurrentUserId)
            {
                <form method="post" asp-page-handler="RemoveMember">
                    <input type="hidden" name="targetUserId" value="@m.UserId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            data-confirm="@L["Confirm.RemoveMember", m.DisplayName]">@L["Dashboard.Remove"]</button>
                </form>
            }
        </div>
    }
</div>

<p class="section-title">@L["Dashboard.Invite"]</p>
<form method="post" asp-page-handler="Invite">
    <button type="submit" class="btn btn-outline-secondary btn-sm">@L["Dashboard.GenerateInvite"]</button>
</form>

@if (Model.InviteToken is not null)
{
    var joinUrl = $"{Request.Scheme}://{Request.Host}/households/join?token={Model.InviteToken}";
    var displayUrl = joinUrl.Length > 60 ? joinUrl[..60] + "…" : joinUrl;
    <div class="invite-card">
        <div class="invite-card-label">@L["Dashboard.InviteSingleUse"]</div>
        <div class="invite-card-url">@displayUrl</div>
        <div class="invite-card-actions">
            <button class="invite-card-btn invite-btn-copy"
                    data-invite-url="@joinUrl"
                    onclick="copyInviteUrl(this)">
                ⧉ @L["Dashboard.Copy"]
            </button>
            <button class="invite-card-btn invite-btn-share"
                    data-invite-url="@joinUrl"
                    style="display:none"
                    onclick="shareInviteUrl(this)">
                ↗ Share
            </button>
        </div>
        <div class="invite-card-hint">@L["Dashboard.InviteSingleUseHint"]</div>
    </div>
}

@section Scripts {
    <script src="~/js/push.js" asp-append-version="true"></script>
}
