@page
@model HouseholdApp.Web.Pages.Households.JoinHouseholdModel
@{
    ViewData["Title"] = L["Households.Join.Title"];
}

<h1>@L["Households.Join.Title"]</h1>

@if (Model.Token is null)
{
    <div class="alert alert-danger">@L["Households.Join.InvalidTokenAlert"]</div>
}
else if (Model.AlreadyJoined)
{
    <div class="alert alert-info">@L["Households.Join.AlreadyJoinedAlert"]</div>
    <a asp-page="Index" class="btn btn-primary">@L["Households.Join.GoToMyHouseholds"]</a>
}
else
{
    <p>@L["Households.Join.InviteMessage"]</p>
    <form method="post">
        <input type="hidden" asp-for="Token" />
        <button type="submit" class="btn btn-success">@L["Households.Join.Accept"]</button>
        <a asp-page="Index" class="btn btn-outline-secondary ms-2">@L["Households.Join.Decline"]</a>
    </form>
}
