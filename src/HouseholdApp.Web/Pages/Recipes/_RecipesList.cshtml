@model HouseholdApp.Web.Pages.Recipes.RecipesListViewModel

<div id="recipes-list">
@if (!Model.Recipes.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var r in Model.Recipes)
    {
        <a href="/h/@Model.HouseholdId/recipes/@r.Id"
           class="list-row" style="align-items:flex-start;text-decoration:none;color:inherit">
            <div class="list-row-icon" style="background:rgba(255,107,74,0.12)">🍳</div>
            <div class="list-row-body">
                <div class="list-row-name">@r.Title</div>
                @if (r.Description is not null)
                {
                    <div class="list-row-meta">@r.Description</div>
                }
                @if (r.Servings.HasValue)
                {
                    <div class="list-row-meta">@r.Servings @L["Recipes.ServingsLabel"]</div>
                }
            </div>
            <span style="color:var(--text-muted);font-size:18px;padding-left:8px">›</span>
        </a>
    }
}
</div>
