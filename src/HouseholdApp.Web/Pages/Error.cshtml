@page
@model ErrorModel
@{
    ViewData["Title"] = L["Common.Error"];
}

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:64px 24px;text-align:center;gap:16px">
    <div style="font-family:var(--font-display);font-size:96px;font-weight:700;line-height:1;color:var(--text-primary);opacity:0.15">500</div>
    <div style="font-family:var(--font-display);font-size:24px;font-weight:600;color:var(--text-primary);margin-top:-16px">@L["Common.Error"]</div>
    <div style="font-size:14px;color:var(--text-muted);max-width:320px">@L["Common.ErrorDetail"]</div>
    @if (Model.ShowRequestId)
    {
        <div style="font-size:11px;color:var(--text-muted);font-family:monospace;opacity:0.6">ID: @Model.RequestId</div>
    }
    <a asp-page="/Households/Index" class="btn btn-primary" style="margin-top:8px">@L["Common.GoHome"]</a>
</div>
