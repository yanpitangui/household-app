@page "/Settings"
@model SettingsModel
@{
    ViewData["Title"] = L["Settings.Title"];
    var referer = Request.Headers["Referer"].ToString();
    var returnUrl = Uri.EscapeDataString(referer.Length > 0 ? referer : "/");
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:28px">
    <a href="javascript:history.back()" class="app-settings" style="color:var(--text-secondary)">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:22px;height:22px">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <h1 style="font-family:var(--font-display);font-size:24px;font-weight:600;color:var(--text-primary);margin:0">@L["Settings.Title"]</h1>
</div>

<p class="section-title">@L["Settings.Language"]</p>
<div class="app-card" style="display:flex;gap:10px;padding:14px 16px">
    <a href="/set-culture?culture=en&returnUrl=@returnUrl" hx-boost="false"
       class="btn btn-sm @(Model.CurrentCulture.StartsWith("en") ? "btn-primary" : "btn-outline-secondary")"
       style="flex:1;text-align:center">
        🇺🇸 English
    </a>
    <a href="/set-culture?culture=pt-BR&returnUrl=@returnUrl" hx-boost="false"
       class="btn btn-sm @(Model.CurrentCulture == "pt-BR" ? "btn-primary" : "btn-outline-secondary")"
       style="flex:1;text-align:center">
        🇧🇷 Português
    </a>
</div>
