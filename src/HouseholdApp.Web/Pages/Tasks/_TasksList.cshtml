@model HouseholdApp.Web.Pages.Tasks.TasksListViewModel

<div id="tasks-list">
@if (!Model.Tasks.Any())
{
    <p class="section-title">@L["Common.NoItemsYet"]</p>
}
else
{
    @foreach (var t in Model.Tasks)
    {
        <div class="list-row" style="align-items:center">
            <form method="post" action="/h/@Model.HouseholdId/tasks?handler=@(t.Status == "Completed" ? "Uncomplete" : "Complete")" style="display:inline-flex; align-items:center; flex-shrink:0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="taskId" value="@t.Id" />
                <button type="submit" class="check-box @(t.Status == "Completed" ? "checked" : "")" style="--check-accent:var(--accent-tasks)">✓</button>
            </form>
            <div class="list-row-body">
                <div class="list-row-name @(t.Status == "Completed" ? "text-decoration-line-through" : "")" style="@(t.Status == "Completed" ? "color:var(--text-muted)" : "")">@t.Title</div>
                <div class="list-row-meta">
                    @if (t.AssignedTo.HasValue)
                    {
                        <span>@(Model.MemberNames.GetValueOrDefault(t.AssignedTo.Value, "?"))</span>
                    }
                    @if (t.DueDate.HasValue)
                    {
                        <span class="ms-2">@L["Tasks.DuePrefix"] @t.DueDate.Value.ToString("d")</span>
                    }
                </div>
            </div>
            <div class="d-flex gap-1 align-items-center">
                <form method="post" action="/h/@Model.HouseholdId/tasks?handler=Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ShowCompleted" value="@Model.ShowCompleted.ToString().ToLowerInvariant()" />
                    <input type="hidden" name="taskId" value="@t.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            data-confirm="@L["Confirm.DeleteTask"]">✕</button>
                </form>
            </div>
        </div>
    }
}
</div>
